<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.logistica.viewController.DashboardController" stylesheets="@../css/styles.css" styleClass="root">
    
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #16213e;">
            <Label text="BookIt Administrador" styleClass="title-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Generar Reporte PDF" onAction="#generarPDF" styleClass="button-primary"/>
            <Button text="Generar Reporte CSV" onAction="#generarCSV" styleClass="button-primary"/>
            <Button text="Cerrar Sesión" onAction="#logout" style="-fx-background-color: #555; -fx-text-fill: white; -fx-padding: 10; -fx-cursor: hand;" />
        </HBox>
    </top>
    
    <center>
        <VBox spacing="20" alignment="CENTER" style="-fx-padding: 30;">
            <Label text="Panel de Métricas" styleClass="title-label" />
            <PieChart fx:id="ventasPorZonaChart" title="Ocupación por Zona (Simulación)" />
        </VBox>
    </center>

</BorderPane>
