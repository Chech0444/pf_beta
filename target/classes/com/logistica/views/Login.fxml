<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.logistica.viewController.LoginController" style="-fx-background-color: #1a1a2e;">
    <padding><Insets top="40" bottom="40" left="40" right="40"/></padding>
    
    <Label text="BookIt - Plataforma de Eventos" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;" />
    <Label text="Inicia sesión para continuar" style="-fx-font-size: 14; -fx-text-fill: #a0a0a0;" />
    
    <VBox spacing="8" maxWidth="320" alignment="CENTER_LEFT">
        <Label text="Correo:" style="-fx-text-fill: white;" />
        <TextField fx:id="txtCorreo" promptText="admin@logistica.com" style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #0f3460; -fx-padding: 8;" />
        <Label text="Contraseña:" style="-fx-text-fill: white;" />
        <PasswordField fx:id="txtPassword" promptText="****" style="-fx-background-color: #16213e; -fx-text-fill: white; -fx-border-color: #0f3460; -fx-padding: 8;" />
    </VBox>
    
    <Button text="INICIAR SESIÓN" onAction="#handleLogin" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-cursor: hand;" />
    <Label fx:id="lblError" style="-fx-text-fill: #e94560;" />
</VBox>
