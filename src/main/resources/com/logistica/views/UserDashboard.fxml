<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.logistica.viewController.UserDashboardController"
            stylesheets="@../css/styles.css">
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
            <Label text="🎫 BookIt" styleClass="label-title" style="-fx-font-size: 20;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Mi Perfil" onAction="#verPerfil" styleClass="btn-ghost"/>
            <Button text="Mis Compras" onAction="#verCompras" styleClass="btn-ghost"/>
            <Button text="Cerrar Sesión" onAction="#logout" styleClass="button"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="14" style="-fx-padding: 20;">
            <Label text="Explorar Eventos" styleClass="label-title" style="-fx-font-size: 22;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtFiltroCiudad" promptText="Ciudad" prefWidth="140"/>
                <TextField fx:id="txtFiltroCategoria" promptText="Categoría" prefWidth="140"/>
                <TextField fx:id="txtFiltroPrecio" promptText="Precio máximo" prefWidth="130"/>
                <Button text="🔍 Buscar" onAction="#filtrarEventos" styleClass="btn-primary"/>
                <Button text="Limpiar" onAction="#limpiarFiltros" styleClass="btn-ghost"/>
            </HBox>
            <Separator/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                <FlowPane fx:id="flowEventos" hgap="16" vgap="16" style="-fx-padding: 5;"/>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
